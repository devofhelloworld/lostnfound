<%- include('partials/nav')%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h2 class="text-3xl font-bold text-gray-800 mb-8">Search Results:</h2>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
<%founddata.forEach(item =>{ %>
  
    <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition">
        <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
            <i class="fas fa-mobile-alt text-white text-6xl"></i>
        </div>
        <div class="p-6">
            <div class="flex items-center justify-between mb-2">
                <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded"><%=item.category%></span>
                <span class="text-gray-500 text-sm">2 days ago</span>
            </div>
            <h3 class="text-xl font-semibold text-gray-800 mb-2"><%=item.itemname%></h3>
            <p class="text-gray-600 line-clamp-1 mb-4"><%=item.ddes%></p>
            <div class="flex items-center text-gray-600 text-sm mb-4">
                <i class="fas fa-map-marker-alt mr-2"></i>
                <span><%=item.currentlocation%></span>
            </div>
            <a href="/found_items/<%= item._id%>">
            <button class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 transition font-semibold">
                Details
            </button></a>
        </div>
    </div>
 
  <% });%>
</div>
<div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-6 <%=show%>">
  <div class="flex items-start">
      <i class="fas fa-info-circle text-blue-500 text-xl mr-3 mt-1"></i>
      <div>
          <h3 class="text-blue-800 font-semibold mb-2">No Item Found!</h3>
          <p class="text-blue-700 mb-2">We suggest you to try these</p>
          <ul class="text-blue-700 space-y-1 ml-4">
              <li>• Use short keywords. Example: Iphone instead of Iphone 16 Pro Max</li>
              <li>• Visit Found Page by clicking <a class="font-bold" href="/found_items">here</a></li>
          </ul>
      </div>
  </div>
</div>
</div>
 </div>
 
 



 <%- include('partials/footer')%>