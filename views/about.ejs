<%- include('partials/nav')%>

<!-- ── Hero ─────────────────────────────────────────────────────────────── -->
<div class="relative bg-slate-950 text-white overflow-hidden py-24 border-b border-white/5">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/60 via-slate-950 to-slate-950"></div>
  <div class="absolute top-1/4 left-1/10 w-96 h-96 bg-purple-600/10 rounded-full blur-[120px] animate-pulse"></div>
  <div class="absolute bottom-1/4 right-1/10 w-96 h-96 bg-indigo-600/10 rounded-full blur-[120px] animate-pulse" style="animation-delay:2s"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/30 backdrop-blur-md px-4 py-2 rounded-full mb-8">
      <i class="fas fa-info-circle text-indigo-400 text-sm"></i>
      <span class="text-xs font-semibold uppercase tracking-wider text-indigo-300">About the Platform</span>
    </div>
    <h1 class="text-5xl md:text-6xl font-extrabold mb-6 leading-tight tracking-tight">
      Built for Campus.<br>
      <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Built with Care.</span>
    </h1>
    <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
      Lost &amp; Found NIT Patna is a student-built platform that helps the campus community report, discover,
      and recover lost belongings — fast, securely, and without paperwork.
    </p>
  </div>
</div>

<!-- ── Mission ───────────────────────────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

    <!-- Left: text -->
    <div>
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-3 py-1 rounded-full mb-4">Our Mission</span>
      <h2 class="text-4xl font-extrabold text-slate-900 mb-6 leading-tight">
        Reuniting Students<br>with Their Belongings
      </h2>
      <p class="text-slate-500 text-base leading-relaxed mb-6">
        Every semester, hundreds of items — phones, wallets, ID cards, laptops — go missing on campus.
        The old way was to post flyers or shout on group chats, hoping someone would see it. We built
        something better.
      </p>
      <p class="text-slate-500 text-base leading-relaxed mb-8">
        Our platform creates a structured, searchable record of every found and lost item on campus.
        Anyone can report, anyone can search, and the claim process is verified to prevent fraud.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/found_items" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white px-6 py-3 rounded-xl font-bold text-sm shadow-md hover:shadow-indigo-500/20 hover:scale-[1.02] transition-all">
          <i class="fas fa-box-open text-xs"></i> Browse Found Items
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white border border-slate-200 hover:bg-slate-50 text-slate-800 px-6 py-3 rounded-xl font-bold text-sm shadow-sm hover:shadow transition-all">
          <i class="fas fa-envelope text-indigo-400 text-xs"></i> Contact Us
        </a>
      </div>
    </div>

    <!-- Right: visual stat cards -->
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-gradient-to-br from-indigo-600 to-purple-700 rounded-3xl p-7 text-white shadow-xl shadow-indigo-500/20 col-span-2">
        <i class="fas fa-shield-halved text-white/60 text-3xl mb-4"></i>
        <p class="text-4xl font-extrabold mb-1">100%</p>
        <p class="text-indigo-200 text-sm font-semibold">Verification-backed claims</p>
        <p class="text-white/60 text-xs mt-2 leading-relaxed">Every claim is tied to a verified campus account — no anonymous pickups.</p>
      </div>
      <div class="bg-white rounded-3xl p-6 shadow-md border border-slate-100 flex flex-col justify-between">
        <div class="w-10 h-10 bg-emerald-50 rounded-2xl flex items-center justify-center mb-3">
          <i class="fas fa-handshake text-emerald-600"></i>
        </div>
        <div>
          <p class="text-2xl font-extrabold text-slate-900">Fast</p>
          <p class="text-slate-500 text-xs font-semibold mt-1">Average reunion under 48 hrs</p>
        </div>
      </div>
      <div class="bg-white rounded-3xl p-6 shadow-md border border-slate-100 flex flex-col justify-between">
        <div class="w-10 h-10 bg-amber-50 rounded-2xl flex items-center justify-center mb-3">
          <i class="fas fa-lock text-amber-600"></i>
        </div>
        <div>
          <p class="text-2xl font-extrabold text-slate-900">Secure</p>
          <p class="text-slate-500 text-xs font-semibold mt-1">Session-based authentication</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── How It Works ───────────────────────────────────────────────────────── -->
<div class="bg-slate-950 text-white py-24 border-t border-b border-white/5 relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-500/5 rounded-full blur-[160px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 px-3 py-1 rounded-full mb-4">The Process</span>
      <h2 class="text-4xl font-extrabold mb-4">How It Works</h2>
      <p class="text-slate-400 max-w-xl mx-auto text-base">Three simple steps to recover what matters to you.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="relative group">
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-8 hover:border-indigo-500/40 transition-all duration-300 shadow-xl h-full flex flex-col">
          <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-indigo-500/20 group-hover:scale-110 transition-transform">
            <i class="fas fa-file-pen text-white text-xl"></i>
          </div>
          <div class="text-xs font-bold text-indigo-400 uppercase tracking-widest mb-2">Step 1</div>
          <h3 class="text-xl font-bold mb-3">Report It</h3>
          <p class="text-slate-400 text-sm leading-relaxed flex-1">Found something? Submit a Found Report. Lost something? Post a Lost Report. Both take under 2 minutes.</p>
        </div>
        <div class="hidden md:block absolute top-12 -right-4 w-8 h-[2px] bg-gradient-to-r from-indigo-500/50 to-transparent"></div>
      </div>

      <div class="relative group">
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-8 hover:border-purple-500/40 transition-all duration-300 shadow-xl h-full flex flex-col">
          <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform">
            <i class="fas fa-magnifying-glass text-white text-xl"></i>
          </div>
          <div class="text-xs font-bold text-purple-400 uppercase tracking-widest mb-2">Step 2</div>
          <h3 class="text-xl font-bold mb-3">Search &amp; Match</h3>
          <p class="text-slate-400 text-sm leading-relaxed flex-1">Use keyword and category filters to find your item. The live feed updates as new reports come in.</p>
        </div>
        <div class="hidden md:block absolute top-12 -right-4 w-8 h-[2px] bg-gradient-to-r from-purple-500/50 to-transparent"></div>
      </div>

      <div class="group">
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-8 hover:border-emerald-500/40 transition-all duration-300 shadow-xl h-full flex flex-col">
          <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-emerald-500/20 group-hover:scale-110 transition-transform">
            <i class="fas fa-handshake text-white text-xl"></i>
          </div>
          <div class="text-xs font-bold text-emerald-400 uppercase tracking-widest mb-2">Step 3</div>
          <h3 class="text-xl font-bold mb-3">Claim &amp; Reunite</h3>
          <p class="text-slate-400 text-sm leading-relaxed flex-1">File a verified claim. Collect your item from the security office after confirmation.</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ── Values ─────────────────────────────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
  <div class="text-center mb-14">
    <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-3 py-1 rounded-full mb-4">What We Stand For</span>
    <h2 class="text-4xl font-extrabold text-slate-900">Core Values</h2>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

    <div class="group bg-white rounded-2xl p-7 shadow-md hover:shadow-xl border border-slate-100 hover:-translate-y-1 transition-all duration-300">
      <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
        <i class="fas fa-shield-halved text-indigo-600 text-lg"></i>
      </div>
      <h3 class="font-bold text-slate-900 mb-2">Trust</h3>
      <p class="text-slate-500 text-sm leading-relaxed">Every account is campus-authenticated. Every claim is traceable back to a real student.</p>
    </div>

    <div class="group bg-white rounded-2xl p-7 shadow-md hover:shadow-xl border border-slate-100 hover:-translate-y-1 transition-all duration-300">
      <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
        <i class="fas fa-bolt text-emerald-600 text-lg"></i>
      </div>
      <h3 class="font-bold text-slate-900 mb-2">Speed</h3>
      <p class="text-slate-500 text-sm leading-relaxed">Real-time live feeds mean you see new found items the moment they're reported — no lag.</p>
    </div>

    <div class="group bg-white rounded-2xl p-7 shadow-md hover:shadow-xl border border-slate-100 hover:-translate-y-1 transition-all duration-300">
      <div class="w-12 h-12 bg-purple-50 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
        <i class="fas fa-users text-purple-600 text-lg"></i>
      </div>
      <h3 class="font-bold text-slate-900 mb-2">Community</h3>
      <p class="text-slate-500 text-sm leading-relaxed">Built by a student, for students. Every feature was designed with campus life in mind.</p>
    </div>

    <div class="group bg-white rounded-2xl p-7 shadow-md hover:shadow-xl border border-slate-100 hover:-translate-y-1 transition-all duration-300">
      <div class="w-12 h-12 bg-rose-50 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
        <i class="fas fa-lock text-rose-600 text-lg"></i>
      </div>
      <h3 class="font-bold text-slate-900 mb-2">Privacy</h3>
      <p class="text-slate-500 text-sm leading-relaxed">Personal contact details are only revealed after a successful claim match — never publicly exposed.</p>
    </div>

  </div>
</div>

