<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pagetitle%></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-gray-50">
    <nav class="bg-indigo-600 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            <div class="flex items-center">
      
              <span class="text-white text-xl font-bold"><a href="/">Lost & Found NIT Patna</a></span>
            </div>
      
            <!-- Desktop menu -->
            <div class="hidden md:flex gap-0.5 lg:space-x-4">
              <a href="/" class="text-white hover:bg-indigo-700 px-3 py-2 rounded-md transition">Home</a>
              <% if(isloggedin){ %>
              <a href="/lost_items" class="text-white hover:bg-indigo-700 px-3 py-2 rounded-md transition">Lost Items</a>
              <a href="/found_items" class="text-white hover:bg-indigo-700 px-3 py-2 rounded-md transition">Found Items</a>
              <a href="/claimrequests" class="text-white hover:bg-indigo-700 px-3 py-2 rounded-md transition">Claim Requests</a><%}%>
              <a href="/contact" class="text-white hover:bg-indigo-700 px-3 py-2 rounded-md transition">Contact</a>
              

           <%if(isloggedin){ %>
            <a href="/logout" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Logout</a>
              <%}else {%>
                <a href="/login" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Login</a>
                <%}%>
              
            </div>
      
            <!-- Hamburger button (mobile only) -->
            <button id="hamburger" class="md:hidden flex flex-col space-y-1.5 p-2 focus:outline-none" aria-label="Toggle menu">
              <span class="block w-6 h-0.5 bg-white"></span>
              <span class="block w-6 h-0.5 bg-white"></span>
              <span class="block w-6 h-0.5 bg-white"></span>
            </button>
          </div>
        </div>
      
        <!-- Mobile menu (hidden by default) -->
        <div id="mobile-menu" class="hidden md:hidden px-2 pt-2 pb-3 space-y-1 bg-indigo-700">
          <a href="/" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Home</a>
          <% if(isloggedin){ %>
          <a href="/lost_items" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Lost Items</a>
          <a href="/found_items" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Found Items</a>
          <a href="/claimrequests" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Claim Requests</a>
          <%}%>
          <a href="/contact" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Contact</a>
          
           <%if(isloggedin){ %>
          <a href="/logout" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Logout</a>
            <%}else {%>
              <a href="/login" class="block text-white hover:bg-indigo-800 px-3 py-2 rounded-md transition">Login</a>
              <%}%>
        </div>
      </nav>
      
      <script>
        const hamburger = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobile-menu');
      
        hamburger.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      </script>