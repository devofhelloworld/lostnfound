<div class="mt-8 bg-indigo-50/50 border border-indigo-100 rounded-2xl p-6 shadow-sm">
  <div class="flex items-start gap-4">
      <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center flex-shrink-0">
          <i class="fas fa-circle-question text-indigo-650 text-lg"></i>
      </div>
      <div>
          <h3 class="text-indigo-900 font-bold mb-1">Need Help?</h3>
          <p class="text-indigo-850/80 text-sm mb-3 font-medium">If you have questions about reporting a <%= type %> item or need assistance:</p>
          <ul class="text-indigo-850/80 text-sm space-y-2">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></span>
                <span>Email Support: <a href="mailto:lostandfound@college.edu" class="font-bold underline hover:text-indigo-900">lostandfound@college.edu</a></span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></span>
                <span>Security Office: Building A, Ground Floor</span>
              </li>
          </ul>
      </div>
  </div>
</div>
