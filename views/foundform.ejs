<%- include('partials/nav')%>

<div class="relative bg-slate-950 text-white overflow-hidden py-16 border-b border-white/5">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/40 via-slate-950 to-slate-950"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-3xl md:text-4xl font-extrabold mb-2 tracking-tight">Report a Found Item</h1>
    <p class="text-slate-400 text-sm max-w-lg mx-auto">Help reunite lost items with their owners by reporting items found on campus.</p>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8 border border-slate-150">
      <form action="/submit-found-item" method="POST" class="space-y-8">

          <div>
              <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                  <div class="w-8 h-8 bg-indigo-50 rounded-xl flex items-center justify-center border border-indigo-100/50">
                    <i class="fas fa-box text-indigo-600 text-xs"></i>
                  </div>
                  Item Information
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                  <div class="md:col-span-2">
                      <label class="block text-slate-700 text-xs font-bold mb-2">
                          Item Name <span class="text-rose-500">*</span>
                      </label>
                      <input
                          type="text"
                          name="itemname"
                          required
                          placeholder="e.g., iPhone 13, Blue Backpack, Chemistry Textbook"
                          class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
                  </div>

                  <div>
                      <label class="block text-slate-700 text-xs font-bold mb-2">
                          Category <span class="text-rose-500">*</span>
                      </label>
                      <select
                          name="category"
                          required
                          class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-650 font-medium text-sm cursor-pointer bg-white">
                          <option value="">Select a category</option>
                          <option value="Electronics">Electronics</option>
                          <option value="Books & Stationery">Books & Stationery</option>
                          <option value="Clothing & Accessories">Clothing & Accessories</option>
                          <option value="Keys & Cards">Keys & Cards</option>
                          <option value="Bags">Bags & Backpacks</option>
                          <option value="Jewelry & Watches">Jewelry & Watches</option>
                          <option value="Sports">Sports Equipment</option>
                          <option value="Other">Other</option>
                      </select>
                  </div>

                  <div>
                      <label class="block text-slate-700 text-xs font-bold mb-2">
                          Upload Photo (Under Development)
                      </label>
                      <div class="relative border-2 border-dashed border-slate-200 rounded-xl p-3 text-center hover:border-indigo-500/50 transition cursor-pointer" id="dropzone">
                          <input
                              type="file"
                              name="imglink"
                              accept="image/*"
                              class="hidden"
                              id="photoUpload"
                              onchange="previewImage(event)">
                          <label for="photoUpload" class="cursor-pointer block">
                              <div id="upload-icon-container">
                                  <p class="text-slate-500 text-xs font-semibold"><i class="fas fa-cloud-upload-alt text-indigo-500 mr-2"></i>Choose file or drop</p>
                              </div>
                              <div id="image-preview-container" class="hidden flex flex-col items-center justify-center">
                                  <img id="image-preview" class="max-h-20 rounded-lg shadow-sm border border-slate-100 mb-1" src="" alt="Selected Photo">
                                  <span class="text-[10px] font-bold text-rose-500 hover:underline" onclick="removeImage(event)">Remove Image</span>
                              </div>
                          </label>
                      </div>
                  </div>

                  <div class="md:col-span-2">
                      <label class="block text-slate-700 text-xs font-bold mb-2">
                          Detailed Description <span class="text-rose-500">*</span>
                      </label>
                      <textarea
                          name="ddes"
                          required
                          rows="3"
                          placeholder="Provide as many details as possible: where you found it, color, brand, distinctive marks, condition, etc."
                          class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm resize-none"></textarea>
                  </div>
              </div>
          </div>

          <div class="border-t border-slate-100 pt-6">
              <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                  <div class="w-8 h-8 bg-indigo-50 rounded-xl flex items-center justify-center border border-indigo-100/50">
                    <i class="fas fa-user-tag text-indigo-600 text-xs"></i>
                  </div>
                  Your Information
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                  <div>
                      <label class="block text-slate-700 text-xs font-bold mb-2">First Name <span class="text-rose-500">*</span></label>
                      <input
                          value="<%=userdata.fname%>"
                          type="text"
                          name="fname"
                          required
                          class="w-full px-4 py-3 border border-slate-250 bg-slate-50/50 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
                  </div>
                  <div>
                      <label class="block text-slate-700 text-xs font-bold mb-2">Last Name <span class="text-rose-500">*</span></label>
                      <input
                          value="<%=userdata.lname%>"
                          type="text"
                          name="lname"
                          required
                          class="w-full px-4 py-3 border border-slate-250 bg-slate-50/50 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
                  </div>

                  <div>
                      <label class="block text-slate-700 text-xs font-bold mb-2">Phone Number <span class="text-rose-500">*</span></label>
                      <input
                          value="<%=userdata.phone%>"
                          type="tel"
                          name="phone"
                          required
                          class="w-full px-4 py-3 border border-slate-250 bg-slate-50/50 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
                  </div>

                  <div>
                      <label class="block text-slate-700 text-xs font-bold mb-2">Roll Number <span class="text-rose-500">*</span></label>
                      <input
                          value="<%=userdata.roll%>"
                          type="text"
                          name="roll"
                          required
                          class="w-full px-4 py-3 border border-slate-250 bg-slate-50/50 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
                  </div>

                  <div class="md:col-span-2">
                      <label class="block text-slate-700 text-xs font-bold mb-2">
                          Where is the item currently? <span class="text-rose-500">*</span>
                      </label>
                      <select
                          name="currentlocation"
                          required
                          class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-650 font-medium text-sm cursor-pointer bg-white">
                          <option value="">Select current location</option>
                          <option value="security">Campus Security Office</option>
                          <option value="with-me">With Me</option>
                          <option value="department">Department Office</option>
                          <option value="other">Other Location</option>
                      </select>
                  </div>
              </div>
          </div>

          <div class="border-t border-slate-100 pt-6">
              <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                  <div class="w-8 h-8 bg-indigo-50 rounded-xl flex items-center justify-center border border-indigo-100/50">
                    <i class="fas fa-comment text-indigo-600 text-xs"></i>
                  </div>
                  Additional Notes
              </h2>
              <div>
                  <label class="block text-slate-700 text-xs font-bold mb-2">Any extra details?</label>
                  <textarea
                      name="addnote"
                      rows="2.5"
                      placeholder="Add details about where it was found, custody details, or specific identification instructions..."
                      class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm resize-none"></textarea>
              </div>
          </div>

          <div class="border-t border-slate-100 pt-6">
              <label class="flex items-start cursor-pointer select-none">
                  <input
                      type="checkbox"
                      name="terms"
                      required
                      class="mt-1 w-4.5 h-4.5 text-indigo-600 border-slate-350 rounded focus:ring-indigo-500/30">
                  <span class="ml-2.5 text-slate-500 text-xs font-medium leading-relaxed">
                      I confirm that the information provided is accurate and I agree to use the platform honestly. <span class="text-rose-500">*</span>
                  </span>
              </label>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 pt-2">
              <button
                  type="submit"
                  class="flex-1 bg-gradient-to-r from-indigo-550 to-purple-650 bg-indigo-600 text-white px-6 py-3.5 rounded-xl hover:from-indigo-600 hover:to-purple-700 transition-all font-bold text-sm shadow hover:shadow-indigo-500/20 hover:scale-[1.02] flex items-center justify-center gap-2">
                  <i class="fas fa-paper-plane text-xs"></i>
                  Submit Found Report
              </button>
              <button
                  type="reset"
                  class="bg-slate-50 hover:bg-slate-100 text-slate-600 px-5 py-3.5 rounded-xl border border-slate-200 transition-all font-bold text-sm">
                  Clear Form
              </button>
          </div>
      </form>

      <%- include('partials/helpcard')%>
  </div>
</div>

<script>
  function previewImage(event) {
    const input = event.target;
    const file = input.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('upload-icon-container').classList.add('hidden');
        document.getElementById('image-preview').src = e.target.result;
        document.getElementById('image-preview-container').classList.remove('hidden');
      }
      reader.readAsDataURL(file);
    }
  }

  function removeImage(event) {
    event.preventDefault();
    event.stopPropagation();
    document.getElementById('photoUpload').value = '';
    document.getElementById('upload-icon-container').classList.remove('hidden');
    document.getElementById('image-preview-container').classList.add('hidden');
    document.getElementById('image-preview').src = '';
  }
</script>

<%- include('partials/footer')%>
