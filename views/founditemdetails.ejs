<%- include('partials/nav')%>

<%

const categoryStyles = {
  'Electronics': { icon: 'fa-laptop-code', bg: 'from-blue-500 to-indigo-650', badge: 'bg-blue-50 text-blue-750 border-blue-200' },
  'Books & Stationery': { icon: 'fa-book-open', bg: 'from-amber-500 to-orange-605', badge: 'bg-amber-50 text-amber-700 border-amber-200' },
  'Clothing & Accessories': { icon: 'fa-tshirt', bg: 'from-rose-500 to-pink-600', badge: 'bg-rose-50 text-rose-700 border-rose-200' },
  'Keys & Cards': { icon: 'fa-key', bg: 'from-emerald-500 to-teal-650', badge: 'bg-emerald-50 text-emerald-700 border-emerald-200' },
  'Bags': { icon: 'fa-briefcase', bg: 'from-purple-500 to-indigo-600', badge: 'bg-purple-50 text-purple-700 border-purple-200' },
  'Jewelry & Watches': { icon: 'fa-clock', bg: 'from-cyan-500 to-blue-600', badge: 'bg-cyan-50 text-cyan-700 border-cyan-200' },
  'Sports': { icon: 'fa-dumbbell', bg: 'from-green-500 to-emerald-600', badge: 'bg-green-50 text-green-700 border-green-200' },
  'Others': { icon: 'fa-box', bg: 'from-slate-500 to-slate-700', badge: 'bg-slate-50 text-slate-700 border-slate-200' },
  'Other': { icon: 'fa-box', bg: 'from-slate-500 to-slate-700', badge: 'bg-slate-50 text-slate-700 border-slate-200' }
};

const style = categoryStyles[itemdata.category] || { icon: 'fa-box-open', bg: 'from-indigo-500 to-purple-600', badge: 'bg-indigo-50 text-indigo-700 border-indigo-200' };
%>

<div class="relative bg-slate-950 text-white overflow-hidden py-16 border-b border-white/5">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/40 via-slate-950 to-slate-950"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/30 backdrop-blur-md px-4 py-2 rounded-full mb-4">
      <i class="fas fa-box-open text-indigo-400 text-sm"></i>
      <span class="text-xs font-semibold uppercase tracking-wider text-indigo-300"><%=title%> Details</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-extrabold mb-2 tracking-tight"><%=title%> Item Details</h1>
    <p class="text-slate-400 text-sm max-w-lg mx-auto">Review information regarding this found object or submit verification claims to recover it.</p>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="bg-white rounded-3xl shadow-xl border border-slate-150 overflow-hidden">

    <div class="h-48 bg-gradient-to-br <%= style.bg %> relative overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 bg-slate-950/15"></div>
      <div class="w-20 h-20 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/10 shadow-lg">
        <i class="fas <%= style.icon %> text-white text-4xl"></i>
      </div>
    </div>

    <div class="p-8 space-y-8">

      <div class="<%=claimed%>">
        <div class="bg-rose-50 border border-rose-100 rounded-2xl p-4 shadow-sm flex items-start gap-3">
          <i class="fas fa-triangle-exclamation text-rose-500 text-lg mt-0.5"></i>
          <div>
            <h4 class="text-rose-900 font-bold text-sm">Already Claimed</h4>
            <p class="text-rose-800/80 text-xs mt-0.5 leading-relaxed font-semibold">An active claim request has already been filed by someone else for this item.</p>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-100 pb-6">
        <div>
          <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight"><%=itemdata.itemname%></h2>
          <p class="text-slate-400 text-sm mt-1 font-medium">Verification Status:
            <% if (userdata) { %>
              <span class="text-emerald-600 font-bold">Claim Verification Pending</span>
            <% } else { %>
              <span class="text-indigo-600 font-bold">Open for Claims</span>
            <% } %>
          </p>
        </div>
        <div class="self-start sm:self-center">
          <span class="text-sm font-bold px-3 py-1.5 rounded-lg border <%= style.badge %>"><%=itemdata.category%></span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="space-y-6">
          <div>
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
              <i class="fas fa-file-lines"></i> Description
            </h3>
            <p class="text-slate-655 text-sm leading-relaxed font-medium bg-slate-50 p-4 rounded-2xl border border-slate-100/50">
              <%=itemdata.ddes%>
            </p>
          </div>

          <div>
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
              <i class="fas fa-location-dot"></i> Current Location
            </h3>
            <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100/50 flex gap-3 items-center">
              <div class="w-9 h-9 bg-emerald-50 border border-emerald-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <i class="fas fa-location-crosshairs text-emerald-600 text-sm"></i>
              </div>
              <div>
                <p class="text-slate-800 text-sm font-bold capitalize"><%=itemdata.currentlocation%></p>
                <p class="text-slate-400 text-xs font-medium mt-0.5">Please claim items through matching office authorities.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div>
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-1.5">
              <i class="fas fa-user-check"></i> Found & Reported By
            </h3>
            <div class="bg-slate-50 border border-slate-100/50 rounded-2xl p-5 space-y-4">
              <div class="flex items-center gap-3 border-b border-slate-200/50 pb-3">
                <div class="w-10 h-10 bg-indigo-50 border border-indigo-150 rounded-full flex items-center justify-center text-indigo-650 font-bold">
                  <%= itemdata.fname[0].toUpperCase() %><%= itemdata.lname[0].toUpperCase() %>
                </div>
                <div>
                  <h4 class="text-slate-800 font-bold text-sm"><%=itemdata.fname%> <%=itemdata.lname%></h4>
                  <p class="text-slate-400 text-xs mt-0.5">Campus Finder</p>
                </div>
              </div>
              <ul class="text-xs text-slate-650 space-y-2.5 font-medium">
                <li class="flex items-center justify-between">
                  <span class="text-slate-400">Phone Number</span>
                  <a href="tel:<%=itemdata.phone%>" class="text-indigo-650 font-bold hover:underline select-all"><%=itemdata.phone%></a>
                </li>
                <li class="flex items-center justify-between">
                  <span class="text-slate-400">Roll/Student ID</span>
                  <span class="text-slate-800 font-bold"><%=itemdata.roll%></span>
                </li>
              </ul>
            </div>
          </div>

          <% if(itemdata.addnote){ %>
            <div>
              <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                <i class="fas fa-comment-dots"></i> Finder Notes
              </h3>
              <p class="text-slate-500 text-xs leading-relaxed font-medium bg-slate-50/50 border border-slate-100 p-4 rounded-2xl italic">
                "<%=itemdata.addnote%>"
              </p>
            </div>
          <% } %>
        </div>
      </div>

      <% if(userdata != null){ %>
        <div class="border-t border-slate-100 pt-6">
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-1.5">
            <i class="fas fa-signature"></i> Claim Submitted By
          </h3>
          <div class="bg-indigo-50/40 border border-indigo-100/60 rounded-2xl p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 bg-indigo-100 border border-indigo-200 rounded-full flex items-center justify-center text-indigo-700 font-bold text-xs">
                <%= userdata.fname[0].toUpperCase() %><%= userdata.lname[0].toUpperCase() %>
              </div>
              <div>
                <h4 class="text-slate-800 font-bold text-xs"><%=userdata.fname%> <%=userdata.lname%></h4>
                <p class="text-slate-400 text-[10px]">Claimant Account</p>
              </div>
            </div>
            <ul class="text-[11px] text-slate-600 space-y-1.5 font-medium sm:border-l sm:border-slate-200 sm:pl-6 justify-self-start sm:justify-self-stretch w-full">
              <li class="flex items-center justify-between">
                <span class="text-slate-400">Email:</span>
                <a href="mailto:<%=userdata.email%>" class="text-indigo-650 font-bold hover:underline select-all"><%=userdata.email%></a>
              </li>
              <li class="flex items-center justify-between">
                <span class="text-slate-400">Phone:</span>
                <a href="tel:<%=userdata.phone%>" class="text-indigo-650 font-bold hover:underline select-all"><%=userdata.phone%></a>
              </li>
              <li class="flex items-center justify-between">
                <span class="text-slate-400">Student ID:</span>
                <span class="text-slate-800 font-bold"><%=userdata.roll%></span>
              </li>
            </ul>
          </div>
        </div>
      <%}%>

      <div class="flex flex-col sm:flex-row gap-3 border-t border-slate-100 pt-6">
        <form class="<%=disable%> flex-1" action="/claimrequests/<%=itemdata._id%>" method="POST">
          <button type="submit" class="w-full bg-gradient-to-r from-indigo-550 to-purple-650 bg-indigo-600 text-white py-3.5 rounded-xl hover:from-indigo-600 hover:to-purple-700 transition-all font-bold text-sm shadow hover:shadow-indigo-500/20 hover:scale-[1.01] flex items-center justify-center gap-2">
            <i class="fas fa-hand-paper text-xs"></i> Claim This Item
          </button>
        </form>
        <a href="/" class="flex-1">
          <button class="w-full bg-slate-50 hover:bg-slate-100 text-slate-700 py-3.5 rounded-xl border border-slate-200 transition-all font-bold text-sm flex items-center justify-center gap-2">
            <i class="fas fa-arrow-left text-xs"></i> Back to Home
          </button>
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer')%>
