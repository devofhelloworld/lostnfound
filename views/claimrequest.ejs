<%- include('partials/nav')%>
<!-- Header Section -->
<div class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500 text-white overflow-hidden py-16">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-4">
        <i class="fas fa-box-open text-sm"></i>
        <span class="text-sm font-medium">Browse Claimed Items</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">All Claimed Items</h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto">Browse through items that had been marked for claim by the users</p>
    </div>
  </div>

<!-- Items Grid Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">All Claimed Items</h2>
        <p class="text-gray-600 mt-2">Showing all items that are marked for claims</p>
      </div>
      <span class="hidden md:inline-flex px-4 py-2 bg-indigo-50 text-indigo-600 rounded-full text-sm font-medium">
        <i class="fas fa-clock mr-2"></i>Updated daily
      </span>
    </div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
<%founddata.forEach(item =>{ %>
  
    <div class="group bg-white rounded-2xl shadow-md hover:shadow-2xl overflow-hidden transition-all hover:-translate-y-1 border border-gray-100">
        <div class="h-56 bg-gradient-to-br from-green-500 to-teal-600 relative overflow-hidden">
            <div class="absolute inset-0 bg-black/10"></div>
            <div class="absolute inset-0 flex items-center justify-center">
                <i class="fas fa-mobile-alt text-white text-7xl group-hover:scale-110 transition-transform"></i>
            </div>
        </div>
        <div class="p-6">
            <div class="flex items-center justify-between mb-2">
                <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded"><%=item.category%></span>
                <span class="text-gray-500 text-sm">   </span>
            </div>
            <h3 class="text-xl font-semibold text-gray-800 mb-2"><%=item.itemname%></h3>
            <p class="text-gray-600 line-clamp-1 mb-4"><%=item.ddes%></p>
            <div class="flex items-center text-gray-600 text-sm mb-4">
                <i class="fas fa-map-marker-alt mr-2"></i>
                <span><%=item.currentlocation%></span>
            </div>
            <a href="/found_items/<%= item._id%>?claim=true">
            <button class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 transition font-semibold">
                Details
            </button></a>
        </div>
    </div>
 
  <% });%>
</div>
 </div>

 <%- include('partials/footer')%>