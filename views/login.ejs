<%-include('partials/nav')%>

<div class="flex-1 flex items-center justify-center py-16 px-4 sm:px-6 lg:px-8">
  <div class="relative w-full max-w-md">

    <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 rounded-3xl blur opacity-25 animate-pulse-slow"></div>

    <div class="relative bg-white rounded-3xl shadow-xl p-8 border border-slate-100">
      <div class="text-center mb-8">
        <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-indigo-100/50 shadow-sm">
          <i class="fas fa-fingerprint text-indigo-600 text-xl"></i>
        </div>
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Sign In</h2>
        <p class="text-slate-400 text-sm mt-1.5 font-medium">Access your Lost & Found account</p>
      </div>

      <form action="/login" method="POST" class="space-y-6">

        <% if(errormsg.length>0){ %>
          <div class="bg-rose-50 border border-rose-100 rounded-2xl p-4 shadow-sm" role="alert">
            <div class="flex gap-2">
              <i class="fas fa-triangle-exclamation text-rose-500 mt-0.5 flex-shrink-0"></i>
              <ol class="text-xs text-rose-700 font-semibold space-y-1">
                <%errormsg.forEach(error =>{ %>
                  <li class="list-disc ml-4"><%= error%></li>
                <%})%>
              </ol>
            </div>
          </div>
        <%}else if(error!=''){%>
          <div class="bg-rose-50 border border-rose-100 rounded-2xl p-4 shadow-sm" role="alert">
            <div class="flex gap-2.5">
              <i class="fas fa-triangle-exclamation text-rose-500 mt-0.5 flex-shrink-0"></i>
              <p class="text-xs text-rose-700 font-semibold"><%= error%></p>
            </div>
          </div>
        <%}%>

        <div class="space-y-5">

          <div>
            <label class="block text-slate-700 text-sm font-semibold mb-2 flex items-center gap-1.5">
              <i class="fas fa-envelope text-slate-400 text-xs"></i>
              Email Address <span class="text-rose-500">*</span>
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="name@college.edu"
              class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
          </div>

          <div>
            <label class="block text-slate-700 text-sm font-semibold mb-2 flex items-center gap-1.5">
              <i class="fas fa-lock text-slate-400 text-xs"></i>
              Password <span class="text-rose-500">*</span>
            </label>
            <div class="relative flex items-center">
              <input
                type="password"
                name="password"
                required
                id="pass"
                placeholder="••••••••"
                class="w-full pl-4 pr-16 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
              <button
                id="btn1"
                class="absolute right-3 px-3 py-1.5 text-xs font-bold text-indigo-600 hover:bg-indigo-50 rounded-lg transition"
                type="button"
                onclick="toggleInputType('pass','btn1')">
                Show
              </button>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between text-sm">
          <p class="text-slate-500 font-medium">Don't have an account? <a href="/signup" class="text-indigo-650 font-bold hover:underline">Sign up</a></p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <button
            type="submit"
            class="flex-1 bg-gradient-to-r from-indigo-550 to-purple-600 bg-indigo-600 text-white px-6 py-3.5 rounded-xl hover:from-indigo-600 hover:to-purple-700 transition-all font-bold text-sm shadow hover:shadow-indigo-500/20 hover:scale-[1.02] flex items-center justify-center gap-2">
            <i class="fas fa-paper-plane text-xs"></i>
            Submit
          </button>
          <button
            type="reset"
            class="bg-slate-50 hover:bg-slate-100 text-slate-600 px-5 py-3.5 rounded-xl border border-slate-200 transition-all font-bold text-sm">
            Clear
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function toggleInputType(inputId, btnid) {
    const input = document.getElementById(inputId);
    const btn = document.getElementById(btnid);
    if (input.type === "password") {
      input.type = "text";
      btn.textContent = "Hide";
    } else {
      input.type = "password";
      btn.textContent = "Show";
    }
  }
</script>

<%- include('partials/footer')%>
