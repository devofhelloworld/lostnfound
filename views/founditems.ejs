<%- include('partials/nav')%>

<!-- Header Section -->
<div class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500 text-white overflow-hidden py-16">
  <div class="absolute inset-0 bg-black/10"></div>
  <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-4">
      <i class="fas fa-box-open text-sm"></i>
      <span class="text-sm font-medium">Browse Available Items</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Found Items</h1>
    <p class="text-xl text-white/90 max-w-2xl mx-auto">Browse through items that have been found on campus and claim what's yours!</p>
  </div>
</div>

<!-- Items Grid Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">All Found Items</h2>
      <p class="text-gray-600 mt-2">Showing all items currently available for claim</p>
    </div>
    <span class="hidden md:inline-flex px-4 py-2 bg-indigo-50 text-indigo-600 rounded-full text-sm font-medium">
      <i class="fas fa-clock mr-2"></i>Updated daily
    </span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <%founddata.forEach(item =>{ %>
    
    <div class="group bg-white rounded-2xl shadow-md hover:shadow-2xl overflow-hidden transition-all hover:-translate-y-1 border border-gray-100">
      <div class="h-56 bg-gradient-to-br from-blue-500 to-indigo-600 relative overflow-hidden">
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <i class="fas fa-mobile-alt text-white text-7xl group-hover:scale-110 transition-transform"></i>
        </div>
        <div class="absolute top-4 right-4">
          <span class="bg-white/90 backdrop-blur-sm text-blue-600 text-xs font-bold px-3 py-1.5 rounded-full shadow-lg">NEW</span>
        </div>
      </div>
      <div class="p-6">
        <div class="flex items-center justify-between mb-3">
          <span class="bg-blue-50 text-blue-700 text-xs font-semibold px-3 py-1.5 rounded-lg border border-blue-100"><%=item.category%></span>
          <span class="text-gray-500 text-sm font-medium">    </span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2"><%=item.itemname%></h3>
        <p class="text-gray-600 mb-4 line-clamp-1"><%=item.ddes%></p>
        <div class="flex items-center text-gray-500 text-sm mb-5 bg-gray-50 px-3 py-2 rounded-lg">
          <i class="fas fa-map-marker-alt mr-2 text-red-500"></i>
          <span><%=item.currentlocation%></span>
        </div>
        <a href="/found_items/<%= item._id%>">
          <button class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-3 rounded-xl hover:from-indigo-700 hover:to-purple-700 transition-all font-semibold shadow-md hover:shadow-lg">
            View Details <i class="fas fa-arrow-right ml-2"></i>
          </button>
        </a>
      </div>
    </div>

    <% });%>
  </div>

  <!-- Empty State (if no items) -->
  <% if(founddata.length === 0) { %>
  <div class="text-center py-20">
    <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <i class="fas fa-box-open text-gray-400 text-4xl"></i>
    </div>
    <h3 class="text-2xl font-bold text-gray-900 mb-2">No Items Found</h3>
    <p class="text-gray-600 mb-8">There are currently no found items available. Check back later!</p>
    <a href="/">
      <button class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white px-8 py-3 rounded-xl hover:from-indigo-700 hover:to-purple-700 transition-all font-semibold shadow-lg">
        <i class="fas fa-home mr-2"></i>Back to Home
      </button>
    </a>
  </div>
  <% } %>
</div>

<%- include('partials/footer')%>