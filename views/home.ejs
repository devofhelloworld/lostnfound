<%- include('partials/nav')%>

<% if (!isloggedin) { %>
<div id="nitp-notice" class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white px-4 py-3">
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
    <div class="flex items-center gap-3 min-w-0">
      <div class="w-7 h-7 bg-white/15 rounded-lg flex items-center justify-center flex-shrink-0">
        <i class="fas fa-circle-info text-white text-xs"></i>
      </div>
      <p class="text-sm font-medium text-white/95 leading-snug">
        <span class="font-bold">Note:</span>
        To fully access all features — reporting items, filing claims &amp; viewing details —
        <a href="/login" class="underline underline-offset-2 font-bold hover:text-indigo-200 transition-colors">login</a>
        or <a href="/signup" class="underline underline-offset-2 font-bold hover:text-indigo-200 transition-colors">sign up</a>
        with your <span class="font-bold">NIT Patna email</span>
        (<code class="bg-white/15 px-1.5 py-0.5 rounded text-xs font-mono">@nitp.ac.in</code>).
      </p>
    </div>
    <button onclick="document.getElementById('nitp-notice').style.display='none'"
            class="flex-shrink-0 w-7 h-7 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-colors"
            aria-label="Dismiss">
      <i class="fas fa-xmark text-white text-xs"></i>
    </button>
  </div>
</div>
<% } %>


    <% const categoryStyles={ 'Electronics' : { icon: 'fa-laptop-code' , bg: 'from-blue-500 to-indigo-600' ,
        badge: 'bg-blue-50 text-blue-700 border-blue-200' }, 'Books & Stationery' : { icon: 'fa-book-open' ,
        bg: 'from-amber-500 to-orange-600' , badge: 'bg-amber-50 text-amber-700 border-amber-200'
        }, 'Clothing & Accessories' : { icon: 'fa-tshirt' , bg: 'from-rose-500 to-pink-600' ,
        badge: 'bg-rose-50 text-rose-700 border-rose-200' }, 'Keys & Cards' : { icon: 'fa-key' ,
        bg: 'from-emerald-500 to-teal-650' , badge: 'bg-emerald-50 text-emerald-700 border-emerald-200' }, 'Bags' : {
        icon: 'fa-briefcase' , bg: 'from-purple-500 to-indigo-600' ,
        badge: 'bg-purple-50 text-purple-700 border-purple-200' }, 'Jewelry & Watches' : { icon: 'fa-clock' ,
        bg: 'from-cyan-500 to-blue-600' , badge: 'bg-cyan-50 text-cyan-700 border-cyan-200' }, 'Sports' : {
        icon: 'fa-dumbbell' , bg: 'from-green-500 to-emerald-600' , badge: 'bg-green-50 text-green-700 border-green-200'
        }, 'Others' : { icon: 'fa-box' , bg: 'from-slate-500 to-slate-700' ,
        badge: 'bg-slate-50 text-slate-700 border-slate-200' }, 'Other' : { icon: 'fa-box' ,
        bg: 'from-slate-500 to-slate-700' , badge: 'bg-slate-50 text-slate-700 border-slate-200' } };
        function getCategoryStyle(cat) {
        return categoryStyles[cat] || { icon: 'fa-box-open', bg: 'from-indigo-500 to-purple-600', badge: 'bg-indigo-50 text-indigo-700 border-indigo-200' };
        }
        %>

        <div class="relative bg-slate-950 text-white overflow-hidden py-24 border-b border-white/5">
            <div
                class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/60 via-slate-950 to-slate-950">
            </div>

            <div
                class="absolute top-1/4 left-1/10 w-96 h-96 bg-purple-600/10 rounded-full blur-[120px] animate-pulse-slow">
            </div>
            <div class="absolute bottom-1/4 right-1/10 w-96 h-96 bg-indigo-600/10 rounded-full blur-[120px] animate-pulse-slow"
                style="animation-delay: 2s;"></div>

            <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center max-w-3xl mx-auto">
                    <div
                        class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/30 backdrop-blur-md px-4 py-2 rounded-full mb-8 animate-float">
                        <i class="fas fa-shield-halved text-indigo-400 text-sm"></i>
                        <span class="text-xs font-semibold uppercase tracking-wider text-indigo-300">Secure Campus
                            Recovery System</span>
                    </div>
                    <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight tracking-tight">
                        Lost Something on <br class="hidden sm:inline" />
                        <span
                            class="bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent text-glow">Campus?</span>
                    </h1>
                    <p class="text-lg md:text-xl mb-12 text-slate-400 font-normal max-w-2xl mx-auto leading-relaxed">
                        A secure and automated space helping students reunite with their belongings quickly and easily.
                    </p>
                    <div class="flex flex-col sm:flex-row justify-center gap-5">
                        <a href="/lost_form" class="inline-block">
                            <button
                                class="group w-full sm:w-auto bg-gradient-to-r from-indigo-550 to-purple-600 bg-indigo-600 text-white px-8 py-4 rounded-xl font-bold hover:shadow-lg hover:shadow-indigo-500/20 hover:scale-[1.03] transition-all flex items-center justify-center gap-2.5">
                                <i class="fas fa-plus group-hover:rotate-90 transition-transform"></i>
                                Report Lost Item
                            </button>
                        </a>
                        <a href="/found_form" class="inline-block">
                            <button
                                class="group w-full sm:w-auto bg-slate-900 hover:bg-slate-800 border border-slate-700/80 hover:border-slate-600 text-slate-100 px-8 py-4 rounded-xl font-bold hover:scale-[1.03] transition-all flex items-center justify-center gap-2.5 shadow-xl">
                                <i
                                    class="fas fa-hand-holding group-hover:scale-110 transition-transform text-indigo-400"></i>
                                Report Found Item
                            </button>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <form action="/search_results" method="POST">
            <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
                <div class="bg-white rounded-2xl shadow-xl p-5 md:p-6 border border-slate-200/80">
                    <div class="flex flex-col md:flex-row gap-4">
                        <div class="flex-1 relative">
                            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input name="keyword" type="text" placeholder="Search for items..."
                                class="w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition text-slate-800 placeholder-slate-400 font-medium">
                        </div>
                        <div class="md:w-56">
                            <select name="category"
                                class="w-full px-4 py-3.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent appearance-none bg-white transition cursor-pointer text-slate-600 font-medium">
                                <option value="all">All Categories</option>
                                <option value="Electronics">📱 Electronics</option>
                                <option value="Books & Stationery">📚 Books & Stationery</option>
                                <option value="Clothing & Accessories">👕 Clothing & Accessories</option>
                                <option value="Keys & Cards">🔑 Keys & Cards</option>
                                <option value="Bags">🎒 Bags & Backpacks</option>
                                <option value="Jewelry & Watches">💍 Jewelry & Watches</option>
                                <option value="Sports">⚽ Sports Equipment</option>
                                <option value="Others">📦 Others</option>
                            </select>
                        </div>
                        <button type="submit"
                            class="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white px-8 py-3.5 rounded-xl transition-all font-bold shadow-md hover:shadow-indigo-500/20 hover:scale-[1.02] flex items-center justify-center gap-2">
                            <i class="fas fa-search text-sm"></i>Search
                        </button>
                    </div>
                </div>
            </div>
        </form>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                <div
                    class="group bg-white rounded-2xl shadow-md hover:shadow-xl p-8 text-center transition-all duration-300 border border-slate-100 hover:-translate-y-1">
                    <div
                        class="w-14 h-14 bg-indigo-50 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-box-open text-indigo-600 text-xl"></i>
                    </div>
                    <h3 id="stat-items-found"
                        class="text-4xl font-extrabold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent mb-2"
                        data-target="<%= statItemsFound %>">
                        <%= statItemsFound %></h3>
                    <p class="text-slate-500 font-semibold text-sm uppercase tracking-wider">Items Found</p>
                    <span class="inline-flex items-center gap-1 mt-2 text-[10px] font-semibold text-indigo-400 uppercase tracking-widest">
                        <span id="stat-found-dot" class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span> Live
                    </span>
                </div>

                <div
                    class="group bg-white rounded-2xl shadow-md hover:shadow-xl p-8 text-center transition-all duration-300 border border-slate-100 hover:-translate-y-1">
                    <div
                        class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-handshake text-emerald-600 text-xl"></i>
                    </div>
                    <h3 id="stat-items-reunited"
                        class="text-4xl font-extrabold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent mb-2"
                        data-target="<%= statReunited %>">
                        <%= statReunited %></h3>
                    <p class="text-slate-500 font-semibold text-sm uppercase tracking-wider">Items Reunited</p>
                    <span class="inline-flex items-center gap-1 mt-2 text-[10px] font-semibold text-emerald-400 uppercase tracking-widest">
                        <span id="stat-reunited-dot" class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> Live
                    </span>
                </div>

                <div
                    class="group bg-white rounded-2xl shadow-md hover:shadow-xl p-8 text-center transition-all duration-300 border border-slate-100 hover:-translate-y-1">
                    <div
                        class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-clock text-amber-600 text-xl"></i>
                    </div>
                    <h3 id="stat-pending-claims"
                        class="text-4xl font-extrabold bg-gradient-to-r from-amber-600 to-orange-600 bg-clip-text text-transparent mb-2"
                        data-target="<%= statPending %>">
                        <%= statPending %></h3>
                    <p class="text-slate-500 font-semibold text-sm uppercase tracking-wider">Pending Claims</p>
                    <span class="inline-flex items-center gap-1 mt-2 text-[10px] font-semibold text-amber-400 uppercase tracking-widest">
                        <span id="stat-claims-dot" class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> Live
                    </span>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-3xl font-extrabold text-slate-900">Recently Found Items</h2>
                    <p class="text-slate-500 text-sm mt-1">Belongings discovered across campus looking for their owners.
                    </p>
                </div>
                <span
                    class="inline-flex items-center gap-1.5 px-3 py-1 bg-indigo-50 text-indigo-700 rounded-full text-xs font-semibold border border-indigo-100">
                    <i class="fas fa-rotate text-[10px] animate-spin"></i> Live Feed
                </span>
            </div>

            <% let max=3; let limitf=Math.min(max, founddata.length); %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% if (limitf===0) { %>
                        <div
                            class="col-span-full bg-white rounded-2xl p-12 text-center border border-slate-100 shadow-sm">
                            <i class="fas fa-box-open text-4xl text-slate-300 mb-3"></i>
                            <p class="text-slate-500 font-medium">No items found recently</p>
                        </div>
                        <% } %>
                            <% for(let i=0; i < limitf; i++){ let style=getCategoryStyle(founddata[i].category); %>
                                <div
                                    class="group bg-white rounded-2xl shadow-sm hover:shadow-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 border border-slate-150 flex flex-col h-full">
                                    <div
                                        class="h-48 bg-gradient-to-br <%= style.bg %> relative overflow-hidden flex-shrink-0">
                                        <% if (founddata[i].imglink) { %>
                                            <img src="<%= founddata[i].imglink %>"
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                                alt="<%= founddata[i].itemname %>">
                                            <div class="absolute inset-0 bg-slate-950/10"></div>
                                            <% } else { %>
                                                <div class="absolute inset-0 bg-slate-950/15"></div>
                                                <div class="absolute inset-0 flex items-center justify-center">
                                                    <i
                                                        class="fas <%= style.icon %> text-white text-6xl opacity-90 group-hover:scale-110 transition-transform duration-300"></i>
                                                </div>
                                                <% } %>
                                    </div>
                                    <div class="p-6 flex flex-col flex-1 justify-between">
                                        <div>
                                            <div class="flex items-center justify-between mb-3">
                                                <span
                                                    class="text-xs font-bold px-2.5 py-1 rounded-lg border <%= style.badge %>">
                                                    <%=founddata[i].category%>
                                                </span>
                                                <span class="text-slate-400 text-xs font-medium"><i
                                                        class="far fa-clock mr-1"></i>Recent</span>
                                            </div>
                                            <h3 class="text-lg font-bold text-slate-900 mb-2 line-clamp-1">
                                                <%=founddata[i].itemname%>
                                            </h3>
                                            <p class="text-slate-500 text-sm mb-4 line-clamp-2 leading-relaxed">
                                                <%=founddata[i].ddes%>
                                            </p>
                                        </div>
                                        <div>
                                            <div
                                                class="flex items-center text-slate-500 text-xs mb-5 bg-slate-50 px-3.5 py-2.5 rounded-xl border border-slate-100">
                                                <i class="fas fa-location-dot mr-2 text-rose-500"></i>
                                                <span class="font-medium line-clamp-1">
                                                    <%=founddata[i].currentlocation%>
                                                </span>
                                            </div>
                                            <a href="/found_items/<%=founddata[i]._id.toString()%>"
                                                class="block w-full">
                                                <button
                                                    class="w-full bg-slate-900 text-white py-3 rounded-xl hover:bg-indigo-600 transition-all font-bold text-sm flex items-center justify-center gap-2 group-hover:shadow-md">
                                                    View Details <i
                                                        class="fas fa-arrow-right text-[10px] group-hover:translate-x-1 transition-transform"></i>
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <%}%>
            </div>

            <% if (founddata.length> 0) { %>
                <div class="text-center mt-10">
                    <a href="/found_items" class="inline-block">
                        <button
                            class="inline-flex items-center gap-2 bg-white hover:bg-slate-50 text-slate-800 px-6 py-3 rounded-xl border border-slate-200 transition-all font-bold text-sm shadow-sm hover:shadow">
                            View All Items <i class="fas fa-arrow-right text-xs"></i>
                        </button>
                    </a>
                </div>
                <% } %>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-3xl font-extrabold text-slate-900">Recently Lost Items</h2>
                    <p class="text-slate-500 text-sm mt-1">Postings from campus members who have misplaced belongings.
                    </p>
                </div>
                <span
                    class="inline-flex items-center gap-1.5 px-3 py-1 bg-rose-50 text-rose-700 rounded-full text-xs font-semibold border border-rose-100">
                    <i class="fas fa-magnifying-glass text-[10px] animate-pulse"></i> Searching
                </span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% let limitl=Math.min(max, lostdata.length); %>
                    <% if (limitl===0) { %>
                        <div
                            class="col-span-full bg-white rounded-2xl p-12 text-center border border-slate-100 shadow-sm">
                            <i class="fas fa-search text-4xl text-slate-300 mb-3"></i>
                            <p class="text-slate-500 font-medium">No items reported lost recently</p>
                        </div>
                        <% } %>
                            <% for(let i=0; i < limitl; i++){ let style=getCategoryStyle(lostdata[i].category); %>
                                <div
                                    class="group bg-white rounded-2xl shadow-sm hover:shadow-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 border border-slate-150 flex flex-col h-full">
                                    <div
                                        class="h-48 bg-gradient-to-br <%= style.bg %> relative overflow-hidden flex-shrink-0">
                                        <% if (lostdata[i].imglink) { %>
                                            <img src="<%= lostdata[i].imglink %>"
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                                alt="<%= lostdata[i].itemname %>">
                                            <div class="absolute inset-0 bg-slate-950/10"></div>
                                            <% } else { %>
                                                <div class="absolute inset-0 bg-slate-950/15"></div>
                                                <div class="absolute inset-0 flex items-center justify-center">
                                                    <i
                                                        class="fas <%= style.icon %> text-white text-6xl opacity-90 group-hover:scale-110 transition-transform duration-300"></i>
                                                </div>
                                                <% } %>
                                    </div>
                                    <div class="p-6 flex flex-col flex-1 justify-between">
                                        <div>
                                            <div class="flex items-center justify-between mb-3">
                                                <span
                                                    class="text-xs font-bold px-2.5 py-1 rounded-lg border <%= style.badge %>">
                                                    <%=lostdata[i].category%>
                                                </span>
                                                <span class="text-slate-400 text-xs font-medium"><i
                                                        class="far fa-clock mr-1"></i>Recent</span>
                                            </div>
                                            <h3 class="text-lg font-bold text-slate-900 mb-2 line-clamp-1">
                                                <%=lostdata[i].itemname%>
                                            </h3>
                                            <p class="text-slate-500 text-sm mb-4 line-clamp-2 leading-relaxed">
                                                <%=lostdata[i].ddes%>
                                            </p>
                                        </div>
                                        <div>
                                            <div
                                                class="flex items-center text-slate-500 text-xs mb-5 bg-slate-50 px-3.5 py-2.5 rounded-xl border border-slate-100">
                                                <i class="fas fa-location-dot mr-2 text-rose-500"></i>
                                                <span class="font-medium line-clamp-1">
                                                    <%=lostdata[i].llocation%>
                                                </span>
                                            </div>
                                            <a href="/lost_items/<%=lostdata[i]._id.toString()%>" class="block w-full">
                                                <button
                                                    class="w-full bg-slate-900 text-white py-3 rounded-xl hover:bg-indigo-600 transition-all font-bold text-sm flex items-center justify-center gap-2 group-hover:shadow-md">
                                                    View Details <i
                                                        class="fas fa-arrow-right text-[10px] group-hover:translate-x-1 transition-transform"></i>
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <%}%>
            </div>

            <% if (lostdata.length> 0) { %>
                <div class="text-center mt-10">
                    <a href="/lost_items" class="inline-block">
                        <button
                            class="inline-flex items-center gap-2 bg-white hover:bg-slate-50 text-slate-800 px-6 py-3 rounded-xl border border-slate-200 transition-all font-bold text-sm shadow-sm hover:shadow">
                            View All Items <i class="fas fa-arrow-right text-xs"></i>
                        </button>
                    </a>
                </div>
                <% } %>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-3xl font-extrabold text-slate-900">Recently Claimed Items</h2>
                    <p class="text-slate-500 text-sm mt-1">Items currently marked for verification and reunion.</p>
                </div>
                <span
                    class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-50 text-emerald-700 rounded-full text-xs font-semibold border border-emerald-100">
                    <i class="fas fa-clipboard-check text-[10px]"></i> Claim Verification
                </span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% let limitc=Math.min(max, claimdata.length); %>
                    <% if (limitc===0) { %>
                        <div
                            class="col-span-full bg-white rounded-2xl p-12 text-center border border-slate-100 shadow-sm">
                            <i class="fas fa-handshake-angle text-4xl text-slate-350 mb-3"></i>
                            <p class="text-slate-500 font-medium">No claims pending at this moment</p>
                        </div>
                        <% } %>
                            <% for(let i=0; i < limitc; i++){ if (!claimdata[i]) continue; let
                                style=getCategoryStyle(claimdata[i].category); %>
                                <div
                                    class="group bg-white rounded-2xl shadow-sm hover:shadow-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 border border-slate-150 flex flex-col h-full opacity-90">
                                    <div
                                        class="h-48 bg-gradient-to-br <%= style.bg %> relative overflow-hidden flex-shrink-0">
                                        <% if (claimdata[i].imglink) { %>
                                            <img src="<%= claimdata[i].imglink %>"
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                                alt="<%= claimdata[i].itemname %>">
                                            <div class="absolute inset-0 bg-slate-950/10"></div>
                                            <% } else { %>
                                                <div class="absolute inset-0 bg-slate-950/20"></div>
                                                <div class="absolute inset-0 flex items-center justify-center">
                                                    <i
                                                        class="fas <%= style.icon %> text-white text-6xl opacity-80 group-hover:scale-110 transition-transform duration-300"></i>
                                                </div>
                                                <% } %>
                                                    <div
                                                        class="absolute top-3 right-3 bg-emerald-600 text-white text-[10px] font-bold px-2 py-1 rounded-md uppercase tracking-wider flex items-center gap-1 shadow-md">
                                                        <i class="fas fa-check-circle"></i> Claimed
                                                    </div>
                                    </div>
                                    <div class="p-6 flex flex-col flex-1 justify-between">
                                        <div>
                                            <div class="flex items-center justify-between mb-3">
                                                <span
                                                    class="text-xs font-bold px-2.5 py-1 rounded-lg border <%= style.badge %>">
                                                    <%=claimdata[i].category%>
                                                </span>
                                                <span class="text-slate-400 text-xs font-medium"><i
                                                        class="far fa-clock mr-1"></i>Pending</span>
                                            </div>
                                            <h3 class="text-lg font-bold text-slate-900 mb-2 line-clamp-1">
                                                <%=claimdata[i].itemname%>
                                            </h3>
                                            <p class="text-slate-500 text-sm mb-4 line-clamp-2 leading-relaxed">
                                                <%=claimdata[i].ddes%>
                                            </p>
                                        </div>
