<%- include('partials/nav')%>

    <!-- Hero Section -->
    <div class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Lost Something on Campus?</h1>
            <p class="text-xl mb-8">We're here to help reunite you with your belongings</p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
              <a href="/lost_form">
                <button class="bg-white text-indigo-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition shadow-lg">
                    <i class="fas fa-plus mr-2"></i>Report Lost Item
                </button></a>
                <a href="/found_form">
                <button class="bg-indigo-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-indigo-800 transition shadow-lg">
                    <i class="fas fa-hand-holding mr-2"></i>Report Found Item
                </button></a>
            </div>
        </div>
    </div>

    <!-- Search Bar --><form action="/search_results" method="POST">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8">
        <div class="bg-white rounded-lg shadow-xl p-6">
            <div class="flex flex-col md:flex-row gap-4">
                
                <div class="flex-1">
                    <input name="keyword" type="text" placeholder="Search for items..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                </div>
                <div class="md:w-48">
                    <select name="category" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <option value="all">All Categories</option>
                        <option value="Electronics">Electronics</option>
                          <option value="Books & Stationery">Books & Stationery</option>
                          <option value="Clothing & Accessories">Clothing & Accessories</option>
                          <option value="Keys & Cards">Keys & Cards</option>
                          <option value="Bags">Bags & Backpacks</option>
                          <option value="Jewelry & Watches">Jewelry & Watches</option>
                          <option value="Sports">Sports Equipment</option>
                          <option value="Others">Others</option>
                    </select>
                </div>
                <button type="submit" class="bg-indigo-600 text-white px-8 py-3 rounded-lg hover:bg-indigo-700 transition font-semibold">
                    Search
                </button>
           
            </div>
        </div>
    </div>
 </form>
    <!-- Stats Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white rounded-lg shadow-md p-6 text-center">
                <i class="fas fa-box-open text-indigo-600 text-4xl mb-3"></i>
                <h3 class="text-3xl font-bold text-gray-800 mb-2">97</h3>
                <p class="text-gray-600">Items Found</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-6 text-center">
                <i class="fas fa-handshake text-green-600 text-4xl mb-3"></i>
                <h3 class="text-3xl font-bold text-gray-800 mb-2">189</h3>
                <p class="text-gray-600">Items Reunited</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-6 text-center">
                <i class="fas fa-clock text-orange-600 text-4xl mb-3"></i>
                <h3 class="text-3xl font-bold text-gray-800 mb-2">45</h3>
                <p class="text-gray-600">Pending Claims</p>
            </div>
        </div>
    </div>

    <!-- Recent found Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-8">Recently Found Items</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Item Card 1 -->
            <% 
            let max =3;
            let limitf = Math.min(max,founddata.length);

            %>
            <% for(let i =0;i<limitf;i++){ %>

            

            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition">
                <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                    <i class="fas fa-mobile-alt text-white text-6xl"></i>
                </div>
                <div class="p-6">
                    <div class="flex items-center justify-between mb-2">
                        <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded"><%=founddata[i].category%></span>
                        <span class="text-gray-500 text-sm">2 days ago</span>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2"><%=founddata[i].itemname%></h3>
                    <p class="text-gray-600 mb-4"><%=founddata[i].ddes%></p>
                    <div class="flex items-center text-gray-600 text-sm mb-4">
                        <i class="fas fa-map-marker-alt mr-2"></i>
                        <span><%=founddata[i].currentlocation%></span>
                    </div>
                    <a href="/found_items/<%=founddata[i]._id.toString()%>">
                    <button class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 transition font-semibold">
                        Details
                    </button></a>
                </div>
            </div>
            <%}%>
        </div>

        <div class="text-center mt-8"><a href="/found_items">
            <button class="bg-gray-200 text-gray-700 px-8 py-3 rounded-lg hover:bg-gray-300 transition font-semibold">
                View All Items <i class="fas fa-arrow-right ml-2"></i>
            </button></a>
        </div>
    </div>


    <!-- Recent Items Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-8">Recently Lost Items</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% 
            
            let limitl = Math.min(max,lostdata.length);

            %>
            <!-- Item Card 1 -->
            <% for(let i=0;i<limitl;i++){ %>

            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition">
                <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                    <i class="fas fa-mobile-alt text-white text-6xl"></i>
                </div>
                <div class="p-6">
                    <div class="flex items-center justify-between mb-2">
                        <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded"><%=lostdata[i].category%></span>
                        <span class="text-gray-500 text-sm">2 days ago</span>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2"><%=lostdata[i].itemname%></h3>
                    <p class="text-gray-600 mb-4"><%=lostdata[i].ddes%></p>
                    <div class="flex items-center text-gray-600 text-sm mb-4">
                        <i class="fas fa-map-marker-alt mr-2"></i>
                        <span><%=lostdata[i].llocation%></span>
                    </div>
                    <a href="/lost_items/<%=lostdata[i]._id.toString()%>">
                    <button class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 transition font-semibold">
                        Details
                    </button></a>
                </div>
            </div>
            <%}%>
        </div>

        <div class="text-center mt-8"><a href="/lost_items">
            <button class="bg-gray-200 text-gray-700 px-8 py-3 rounded-lg hover:bg-gray-300 transition font-semibold">
                View All Items <i class="fas fa-arrow-right ml-2"></i>
            </button></a>
        </div>
    </div>


    <!-- Recent Items Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-8">Recently Claimed Items</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Item Card 1 -->
            <% 
            
            let limitc = Math.min(max,claimdata.length);
            %>
            <% for(let i=0;i<limitc;i++){ %>
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition">
                <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                    <i class="fas fa-mobile-alt text-white text-6xl"></i>
                </div>
                <div class="p-6">
                    <div class="flex items-center justify-between mb-2">
                        <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded"><%=claimdata[i].category%></span>
                        <span class="text-gray-500 text-sm">2 days ago</span>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2"><%=claimdata[i].itemname%></h3>
                    <p class="text-gray-600 mb-4"><%=claimdata[i].ddes%></p>
                    <div class="flex items-center text-gray-600 text-sm mb-4">
                        <i class="fas fa-map-marker-alt mr-2"></i>
                        <span><%=claimdata[i].currentlocation%></span>
                    </div>
                    <a href="/found_items/<%=claimdata[i]._id.toString()%>?claim=true">
                    <button class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 transition font-semibold">
                      Details
                    </button></a>
                </div>
            </div>
            <%}%>
        </div>

        <div class="text-center mt-8"> <a href="/claimrequests"> 
            <button class="bg-gray-200 text-gray-700 px-8 py-3 rounded-lg hover:bg-gray-300 transition font-semibold">
                View All Items <i class="fas fa-arrow-right ml-2"></i>
            </button></a>
        </div>
    </div>

    <!-- How It Works Section -->
    <div class="bg-white py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-800 mb-12 text-center">How It Works</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="text-center">
                    <div class="bg-indigo-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                        <span class="text-indigo-600 text-2xl font-bold">1</span>
                    </div>
                    <h3 class="text-xl font-semibold mb-3">Report Item</h3>
                    <p class="text-gray-600">Found or lost something? Report it with details and location.</p>
                </div>
                <div class="text-center">
                    <div class="bg-indigo-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                        <span class="text-indigo-600 text-2xl font-bold">2</span>
                    </div>
                    <h3 class="text-xl font-semibold mb-3">Search & Match</h3>
                    <p class="text-gray-600">Browse items or get notified when there's a match.</p>
                </div>
                <div class="text-center">
                    <div class="bg-indigo-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                        <span class="text-indigo-600 text-2xl font-bold">3</span>
                    </div>
                    <h3 class="text-xl font-semibold mb-3">Get Reunited</h3>
                    <p class="text-gray-600">Claim your item from the campus security office.</p>
                </div>
            </div>
        </div>
    </div>

<%- include('partials/footer')%>
    