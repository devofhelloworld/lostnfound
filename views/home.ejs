<%- include('partials/nav')%>

    <!-- Hero Section -->
    <div class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500 text-white overflow-hidden">
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
        
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
            <div class="text-center max-w-3xl mx-auto">
                <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-6">
                    <i class="fas fa-shield-alt text-sm"></i>
                    <span class="text-sm font-medium">Secure Campus Recovery System</span>
                </div>
                <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">Lost Something on Campus?</h1>
                <p class="text-xl md:text-2xl mb-10 text-white/90">We're here to help reunite you with your belongings</p>
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="/lost_form">
                        <button class="group bg-white text-indigo-600 px-8 py-4 rounded-xl font-semibold hover:bg-gray-50 transition-all shadow-xl hover:shadow-2xl hover:scale-105">
                            <i class="fas fa-plus mr-2 group-hover:rotate-90 transition-transform"></i>Report Lost Item
                        </button>
                    </a>
                    <a href="/found_form">
                        <button class="group bg-indigo-900/50 backdrop-blur-sm text-white px-8 py-4 rounded-xl font-semibold hover:bg-indigo-900/70 transition-all shadow-xl border border-white/20">
                            <i class="fas fa-hand-holding mr-2 group-hover:scale-110 transition-transform"></i>Report Found Item
                        </button>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Bar -->
    <form action="/search_results" method="POST">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10">
            <div class="bg-white rounded-2xl shadow-2xl p-6 md:p-8 border border-gray-100">
                <div class="flex flex-col md:flex-row gap-4">
                    <div class="flex-1 relative">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input name="keyword" type="text" placeholder="Search for items..." class="w-full pl-12 pr-4 py-4 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition">
                    </div>
                    <div class="md:w-56">
                        <select name="category" class="w-full px-4 py-4 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent appearance-none bg-white transition cursor-pointer">
                            <option value="all">All Categories</option>
                            <option value="Electronics">📱 Electronics</option>
                            <option value="Books & Stationery">📚 Books & Stationery</option>
                            <option value="Clothing & Accessories">👕 Clothing & Accessories</option>
                            <option value="Keys & Cards">🔑 Keys & Cards</option>
                            <option value="Bags">🎒 Bags & Backpacks</option>
                            <option value="Jewelry & Watches">💍 Jewelry & Watches</option>
                            <option value="Sports">⚽ Sports Equipment</option>
                            <option value="Others">📦 Others</option>
                        </select>
                    </div>
                    <button type="submit" class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white px-10 py-4 rounded-xl hover:from-indigo-700 hover:to-purple-700 transition-all font-semibold shadow-lg hover:shadow-xl hover:scale-105">
                        <i class="fas fa-search mr-2"></i>Search
                    </button>
                </div>
            </div>
        </div>
    </form>

    <!-- Stats Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl p-8 text-center transition-all hover:-translate-y-1 border border-gray-100">
                <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-indigo-200 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                    <i class="fas fa-box-open text-indigo-600 text-2xl"></i>
                </div>
                <h3 class="text-4xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent mb-2">97</h3>
                <p class="text-gray-600 font-medium">Items Found</p>
            </div>
            <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl p-8 text-center transition-all hover:-translate-y-1 border border-gray-100">
                <div class="w-16 h-16 bg-gradient-to-br from-green-100 to-green-200 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                    <i class="fas fa-handshake text-green-600 text-2xl"></i>
                </div>
                <h3 class="text-4xl font-bold bg-gradient-to-r from-green-600 to-emerald-600 bg-clip-text text-transparent mb-2">189</h3>
                <p class="text-gray-600 font-medium">Items Reunited</p>
            </div>
            <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl p-8 text-center transition-all hover:-translate-y-1 border border-gray-100">
                <div class="w-16 h-16 bg-gradient-to-br from-orange-100 to-orange-200 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                    <i class="fas fa-clock text-orange-600 text-2xl"></i>
                </div>
                <h3 class="text-4xl font-bold bg-gradient-to-r from-orange-600 to-red-600 bg-clip-text text-transparent mb-2">45</h3>
                <p class="text-gray-600 font-medium">Pending Claims</p>
            </div>
        </div>
    </div>

    <!-- Recent found Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Recently Found Items</h2>
            <span class="hidden md:inline-flex px-4 py-2 bg-indigo-50 text-indigo-600 rounded-full text-sm font-medium">
                <i class="fas fa-clock mr-2"></i>Updated daily
            </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Item Card 1 -->
            <% 
            let max =3;
            let limitf = Math.min(max,founddata.length);
            %>
            <% for(let i =0;i<limitf;i++){ %>

            <div class="group bg-white rounded-2xl shadow-md hover:shadow-2xl overflow-hidden transition-all hover:-translate-y-1 border border-gray-100">
                <div class="h-56 bg-gradient-to-br from-blue-500 to-indigo-600 relative overflow-hidden">
                    <div class="absolute inset-0 bg-black/10"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <i class="fas fa-mobile-alt text-white text-7xl group-hover:scale-110 transition-transform"></i>
                    </div>
                </div>
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <span class="bg-blue-50 text-blue-700 text-xs font-semibold px-3 py-1.5 rounded-lg border border-blue-100"><%=founddata[i].category%></span>
                        <span class="text-gray-500 text-sm font-medium">2 days ago</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2"><%=founddata[i].itemname%></h3>
                    <p class="text-gray-600 mb-4 line-clamp-1"><%=founddata[i].ddes%></p>
                    <div class="flex items-center text-gray-500 text-sm mb-5 bg-gray-50 px-3 py-2 rounded-lg">
                        <i class="fas fa-map-marker-alt mr-2 text-red-500"></i>
                        <span><%=founddata[i].currentlocation%></span>
                    </div>
                    <a href="/found_items/<%=founddata[i]._id.toString()%>">
                    <button class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-3 rounded-xl hover:from-indigo-700 hover:to-purple-700 transition-all font-semibold shadow-md hover:shadow-lg">
                        View Details <i class="fas fa-arrow-right ml-2"></i>
                    </button></a>
                </div>
            </div>
            <%}%>
        </div>

        <div class="text-center mt-8"><a href="/found_items">
            <button class="inline-flex items-center gap-3 bg-gray-900 text-white px-8 py-4 rounded-xl hover:bg-gray-800 transition-all font-semibold shadow-lg hover:shadow-xl hover:scale-105">
                View All Items <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </button></a>
        </div>
    </div>


    <!-- Recent Items Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Recently Lost Items</h2>
            <span class="hidden md:inline-flex px-4 py-2 bg-purple-50 text-purple-600 rounded-full text-sm font-medium">
                <i class="fas fa-search mr-2"></i>Searching
            </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% 
            let limitl = Math.min(max,lostdata.length);
            %>
            <!-- Item Card 1 -->
            <% for(let i=0;i<limitl;i++){ %>

            <div class="group bg-white rounded-2xl shadow-md hover:shadow-2xl overflow-hidden transition-all hover:-translate-y-1 border border-gray-100">
                <div class="h-56 bg-gradient-to-br from-purple-500 to-pink-600 relative overflow-hidden">
                    <div class="absolute inset-0 bg-black/10"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <i class="fas fa-mobile-alt text-white text-7xl group-hover:scale-110 transition-transform"></i>
                    </div>
                </div>
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <span class="bg-purple-50 text-purple-700 text-xs font-semibold px-3 py-1.5 rounded-lg border border-purple-100"><%=lostdata[i].category%></span>
                        <span class="text-gray-500 text-sm font-medium">2 days ago</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2"><%=lostdata[i].itemname%></h3>
                    <p class="text-gray-600 mb-4 line-clamp-1"><%=lostdata[i].ddes%></p>
                    <div class="flex items-center text-gray-500 text-sm mb-5 bg-gray-50 px-3 py-2 rounded-lg">
                        <i class="fas fa-map-marker-alt mr-2 text-red-500"></i>
                        <span><%=lostdata[i].llocation%></span>
                    </div>
                    <a href="/lost_items/<%=lostdata[i]._id.toString()%>">
                    <button class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-3 rounded-xl hover:from-indigo-700 hover:to-purple-700 transition-all font-semibold shadow-md hover:shadow-lg">
                        View Details <i class="fas fa-arrow-right ml-2"></i>
                    </button></a>
                </div>
            </div>
            <%}%>
        </div>

        <div class="text-center mt-8"><a href="/lost_items">
            <button class="inline-flex items-center gap-3 bg-gray-900 text-white px-8 py-4 rounded-xl hover:bg-gray-800 transition-all font-semibold shadow-lg hover:shadow-xl hover:scale-105">
                View All Items <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </button></a>
        </div>
    </div>


    <!-- Recent claim Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Recently Claimed Items</h2>
            <span class="hidden md:inline-flex px-4 py-2 bg-green-50 text-green-600 rounded-full text-sm font-medium">
                <i class="fas fa-check-circle mr-2"></i>Pending Review
            </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Item Card 1 -->
            <% 
            let limitc = Math.min(max,claimdata.length);
            %>
            <% for(let i=0;i<limitc;i++){ %>
            <div class="group bg-white rounded-2xl shadow-md hover:shadow-2xl overflow-hidden transition-all hover:-translate-y-1 border border-gray-100">
                <div class="h-56 bg-gradient-to-br from-green-500 to-teal-600 relative overflow-hidden">
                    <div class="absolute inset-0 bg-black/10"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <i class="fas fa-mobile-alt text-white text-7xl group-hover:scale-110 transition-transform"></i>
                    </div>
                </div>
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <span class="bg-green-50 text-green-700 text-xs font-semibold px-3 py-1.5 rounded-lg border border-green-100"><%=claimdata[i].category%></span>
                        <span class="text-gray-500 text-sm font-medium">2 days ago</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2"><%=claimdata[i].itemname%></h3>
                    <p class="text-gray-600 mb-4 line-clamp-1"><%=claimdata[i].ddes%></p>
                    <div class="flex items-center text-gray-500 text-sm mb-5 bg-gray-50 px-3 py-2 rounded-lg">
                        <i class="fas fa-map-marker-alt mr-2 text-red-500"></i>
                        <span><%=claimdata[i].currentlocation%></span>
                    </div>
                    <a href="/found_items/<%=claimdata[i]._id.toString()%>?claim=true">
                    <button class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-3 rounded-xl hover:from-indigo-700 hover:to-purple-700 transition-all font-semibold shadow-md hover:shadow-lg">
                      View Details <i class="fas fa-arrow-right ml-2"></i>
                    </button></a>
                </div>
            </div>
            <%}%>
        </div>

        <div class="text-center mt-8"> <a href="/claimrequests"> 
            <button class="inline-flex items-center gap-3 bg-gray-900 text-white px-8 py-4 rounded-xl hover:bg-gray-800 transition-all font-semibold shadow-lg hover:shadow-xl hover:scale-105">
                View All Items <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </button></a>
        </div>
    </div>

    <!-- How It Works Section -->
    <div class="bg-gradient-to-br from-gray-50 to-indigo-50/30 py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
                <p class="text-xl text-gray-600 max-w-2xl mx-auto">Simple steps to recover your lost items</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="relative">
                    <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border border-gray-100 h-full">
                        <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
                            <span class="text-white text-2xl font-bold">1</span>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-gray-900">Report Item</h3>
                        <p class="text-gray-600 leading-relaxed">Found or lost something? Report it with details and location.</p>
                    </div>
                    <div class="hidden md:block absolute top-1/2 -right-4 w-8 h-0.5 bg-gradient-to-r from-indigo-300 to-transparent"></div>
                </div>
                <div class="relative">
                    <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border border-gray-100 h-full">
                        <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
                            <span class="text-white text-2xl font-bold">2</span>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-gray-900">Search & Match</h3>
                        <p class="text-gray-600 leading-relaxed">Browse items or get notified when there's a match.</p>
                    </div>
                    <div class="hidden md:block absolute top-1/2 -right-4 w-8 h-0.5 bg-gradient-to-r from-purple-300 to-transparent"></div>
                </div>
                <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border border-gray-100">
                    <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-teal-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
                        <span class="text-white text-2xl font-bold">3</span>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-gray-900">Get Reunited</h3>
                    <p class="text-gray-600 leading-relaxed">Claim your item from the campus security office.</p>
                </div>
            </div>
        </div>
    </div>

<%- include('partials/footer')%>