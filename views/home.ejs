<%- include('partials/nav')%>

    <!-- Hero Section -->
    <div class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Lost Something on Campus?</h1>
            <p class="text-xl mb-8">We're here to help reunite you with your belongings</p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
              <a href="/lost_form">
                <button class="bg-white text-indigo-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition shadow-lg">
                    <i class="fas fa-plus mr-2"></i>Report Lost Item
                </button></a>
                <a href="/found_form">
                <button class="bg-indigo-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-indigo-800 transition shadow-lg">
                    <i class="fas fa-hand-holding mr-2"></i>Report Found Item
                </button></a>
            </div>
        </div>
    </div>

    <!-- Search Bar --><form action="/search_results" method="POST">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8">
        <div class="bg-white rounded-lg shadow-xl p-6">
            <div class="flex flex-col md:flex-row gap-4">
                
                <div class="flex-1">
                    <input name="keyword" type="text" placeholder="Search for items..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                </div>
                <div class="md:w-48">
                    <select name="category" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <option value="all">All Categories</option>
                        <option value="Electronics">Electronics</option>
                          <option value="Books & Stationery">Books & Stationery</option>
                          <option value="Clothing & Accessories">Clothing & Accessories</option>
                          <option value="Keys & Cards">Keys & Cards</option>
                          <option value="Bags">Bags & Backpacks</option>
                          <option value="Jewelry & Watches">Jewelry & Watches</option>
                          <option value="Sports">Sports Equipment</option>
                          <option value="Others">Others</option>
                    </select>
                </div>
                <button type="submit" class="bg-indigo-600 text-white px-8 py-3 rounded-lg hover:bg-indigo-700 transition font-semibold">
                    Search
                </button>
           
            </div>
        </div>
    </div>
 </form>
    <!-- Stats Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
