<script>
(function () {
  // Smooth animated counter
  function animateCount(el, from, to, duration) {
    if (from === to) return;
    const start = performance.now();
    function step(now) {
      const progress = Math.min((now - start) / duration, 1);
      // Ease-out cubic
      const ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(from + (to - from) * ease);
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  const statFound   = document.getElementById('stat-items-found');
  const statReunited= document.getElementById('stat-items-reunited');
  const statClaims  = document.getElementById('stat-pending-claims');

  // Pulse dot to signal a live update just arrived
  function flashDot(dotId) {
    const dot = document.getElementById(dotId);
    if (!dot) return;
    dot.classList.remove('animate-pulse');
    dot.style.transform = 'scale(2)';
    dot.style.transition = 'transform 0.3s ease';
    setTimeout(() => {
      dot.style.transform = 'scale(1)';
      setTimeout(() => dot.classList.add('animate-pulse'), 300);
    }, 300);
  }

  function poll() {
    fetch('/api/stats')
      .then(r => r.json())
      .then(data => {
        const prevFound    = parseInt(statFound.textContent,    10);
        const prevReunited = parseInt(statReunited.textContent, 10);
        const prevClaims   = parseInt(statClaims.textContent,   10);

        if (data.itemsFound    !== prevFound)    { animateCount(statFound,    prevFound,    data.itemsFound,    800); flashDot('stat-found-dot'); }
        if (data.itemsReunited !== prevReunited) { animateCount(statReunited, prevReunited, data.itemsReunited, 800); flashDot('stat-reunited-dot'); }
        if (data.pendingClaims !== prevClaims)   { animateCount(statClaims,   prevClaims,  data.pendingClaims,  800); flashDot('stat-claims-dot'); }
      })
      .catch(() => { /* silently ignore network errors */ });
  }

  // Poll every 10 seconds
  setInterval(poll, 10000);
})();
</script>