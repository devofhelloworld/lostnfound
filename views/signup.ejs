<%-include('partials/nav')%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-lg shadow-lg p-6 md:p-8">
      <form action="/signup" method="POST"  class="space-y-6">
          
          
          <!-- Your Information Section -->
          <div >
              <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center">
                  
                  Enter your Information
              </h2>
              <% if(!oldinputs.present){ }else{%>
                <div class="box-border font-semibold p-5 border-dotted mb-8 border-blue-600 bg-red-100 rounded border" role="alert">
                  <ol class="p-3">
                      
                          
                              <li class="list-disc"><span class=" text-red-600 "><%= oldinputs.present%></span></li>
                          
                          
                      </ol>
                </div>
                <%}%>

              <% if(errormsg.length>0){ %>
              <div class="box-border font-semibold p-5 border-dotted mb-8 border-blue-600 bg-red-100 rounded border" role="alert">
                <ol class="p-3">
                    
                        <%errormsg.forEach(error =>{ %>
                            <li class="list-disc"><span class=" text-red-600 "><%= error%></span></li>
                        <%})%>
                        
                    </ol>
              </div>
              <%}%>

              <div class="space-y-4">
                  <!-- Name -->
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div>
                          <label class="block text-gray-700 font-semibold mb-2">
                              First Name <span class="text-red-500">*</span>
                          </label>
                          <input 
                                value="<%= !oldinputs?'':oldinputs.fname%>"
                              type="text" 
                              name="fname"
                              required
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                      </div>
                      <div>
                          <label class="block text-gray-700 font-semibold mb-2">
                              Last Name <span class="text-red-500">*</span>
                          </label>
                          <input 
                          value="<%= !oldinputs?'':oldinputs.lname%>"
                              type="text" 
                              name="lname"
                              required
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                      </div>
                  </div>

                  <!-- Email -->
                  <div>
                      <label class="block text-gray-700 font-semibold mb-2">
                          Email Address <span class="text-red-500">*</span>
                      </label>
                      <input 
                      value="<%= !oldinputs?'':oldinputs.email%>"
                          type="email" 
                          name="email"
                          required
                          placeholder="your.email@college.edu"
                          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                  </div>

                  <!-- Phone -->
                  <div>
                      <label class="block text-gray-700 font-semibold mb-2">
                          Phone Number <span class="text-red-500">*</span>
                      </label>
                      <input 
                      value="<%= !oldinputs?'':oldinputs.phone%>"
                          type="number" 
                          name="phone"
                          required
                          placeholder="(555) 123-4567"
                          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                  </div>

                  <!-- Student/Staff ID -->
                  <div>
                      <label class="block text-gray-700 font-semibold mb-2">
                          Student ID<span class="text-red-500">*</span>
                      </label>
                      <input 
                      value="<%= !oldinputs?'':oldinputs.roll%>"
                          type="number" 
                          name="roll"
                          placeholder="Your college roll number"
                          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" required> 
                  </div>

                  <div>
                    <label class="block text-gray-700 font-semibold mb-2">
                        Password <span class="text-red-500">*</span>
                    </label>
                    <div class="flex text-center justify-center gap-3"><input 
                        type="password" 
                        name="password"
                        required
                        id="pass"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"  >
                        <button id="btn2" class="border rounded-lg p-2 font-semibold border-gray-300" type="button" onclick="toggleInputType('pass','btn2')">Show</button></div>
                    
                </div>
                    
                    <label class="block text-gray-700 font-semibold mb-2">
                        Confirm Password <span class="text-red-500">*</span>
                    </label>
                    <div class="flex text-center justify-center gap-3">
                    <input 
                        type="password" 
                        name="conpassword"
                        required
                        id="conpass"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        <button id="btn1" class="border rounded-lg p-2 font-semibold border-gray-300" type="button" onclick="toggleInputType('conpass','btn1')" >Show</button></div>
                </div>
              </div>
                

          <!-- Terms and Conditions -->
          <div class="border-t pt-6">
              <label class="flex items-start cursor-pointer">
                  <input 
                      type="checkbox" 
                      name="terms"
                      required
                      class="mt-1 w-5 h-5 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
                  <span class="ml-3 text-gray-700">
                      I confirm that the information provided is accurate and I agree to not missuse the platform. <span class="text-red-500">*</span>
                  </span>
              </label>
          </div>

          <!-- Submit Button -->
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
              <button 
                  type="submit"
                  class="flex-1 bg-indigo-600 text-white px-8 py-4 rounded-lg hover:bg-indigo-700 transition font-semibold text-lg shadow-lg hover:shadow-xl">
                  <i class="fas fa-paper-plane mr-2"></i>
                  Submit 
              </button>
              <button 
                  type="reset"
                  class="bg-gray-200 text-gray-700 px-8 py-4 rounded-lg hover:bg-gray-300 transition font-semibold">
                  <i class="fas fa-redo mr-2"></i>
                  Clear Form
              </button>
          </div>
      </form>
  </div>
</div>

<script>
    function toggleInputType(inputId,btnid) {
  const input = document.getElementById(inputId);
  const btn = document.getElementById(btnid)
  if (input.type === "password") {
    input.type = "text";
    btn.textContent = "Hide";
  } else {
    input.type = "password";
    btn.textContent = 'Show';
  }
}
</script>

<%- include('partials/footer')%>