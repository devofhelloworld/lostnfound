<%-include('partials/nav')%>

<div class="flex-1 flex items-center justify-center py-16 px-4 sm:px-6 lg:px-8">
  <div class="relative w-full max-w-lg">

    <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 rounded-3xl blur opacity-20 animate-pulse-slow"></div>

    <div class="relative bg-white rounded-3xl shadow-xl p-8 border border-slate-100">
      <div class="text-center mb-8">
        <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-indigo-100/50 shadow-sm">
          <i class="fas fa-user-plus text-indigo-600 text-xl"></i>
        </div>
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Create Account</h2>
        <p class="text-slate-400 text-sm mt-1.5 font-medium">Join the campus Lost & Found network</p>
      </div>

      <form action="/signup" method="POST" class="space-y-6">

        <% if(oldinputs && oldinputs.present){ %>
          <div class="bg-rose-50 border border-rose-100 rounded-2xl p-4 shadow-sm" role="alert">
            <div class="flex gap-2.5">
              <i class="fas fa-triangle-exclamation text-rose-500 mt-0.5 flex-shrink-0"></i>
              <p class="text-xs text-rose-700 font-semibold"><%= oldinputs.present%></p>
            </div>
          </div>
        <%}%>

        <% if(errormsg.length>0){ %>
          <div class="bg-rose-50 border border-rose-100 rounded-2xl p-4 shadow-sm" role="alert">
            <div class="flex gap-2">
              <i class="fas fa-triangle-exclamation text-rose-500 mt-0.5 flex-shrink-0"></i>
              <ol class="text-xs text-rose-700 font-semibold space-y-1">
                <%errormsg.forEach(error =>{ %>
                  <li class="list-disc ml-4"><%= error%></li>
                <%})%>
              </ol>
            </div>
          </div>
        <%}%>

        <div class="space-y-4">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-slate-700 text-xs font-bold mb-2">First Name <span class="text-rose-500">*</span></label>
              <input
                value="<%= !oldinputs?'':oldinputs.fname%>"
                type="text"
                name="fname"
                required
                placeholder="Jane"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
            </div>
            <div>
              <label class="block text-slate-700 text-xs font-bold mb-2">Last Name <span class="text-rose-500">*</span></label>
              <input
                value="<%= !oldinputs?'':oldinputs.lname%>"
                type="text"
                name="lname"
                required
                placeholder="Doe"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
            </div>
          </div>

          <div>
            <label class="block text-slate-700 text-xs font-bold mb-2 flex items-center gap-1.5">
              <i class="fas fa-envelope text-slate-400 text-[10px]"></i>
              Email Address <span class="text-rose-500">*</span>
            </label>
            <input
              value="<%= !oldinputs?'':oldinputs.email%>"
              type="email"
              name="email"
              required
              placeholder="jane.doe@college.edu"
              class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-slate-700 text-xs font-bold mb-2 flex items-center gap-1.5">
                <i class="fas fa-phone text-slate-400 text-[10px]"></i>
                Phone Number <span class="text-rose-500">*</span>
              </label>
              <input
                value="<%= !oldinputs?'':oldinputs.phone%>"
                type="number"
                name="phone"
                required
                placeholder="9304119915"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
            </div>
            <div>
              <label class="block text-slate-700 text-xs font-bold mb-2 flex items-center gap-1.5">
                <i class="fas fa-id-card text-slate-400 text-[10px]"></i>
                Student ID / Roll <span class="text-rose-500">*</span>
              </label>
              <input
                value="<%= !oldinputs?'':oldinputs.roll%>"
                type="number"
                name="roll"
                required
                placeholder="2103045"
                class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-slate-700 text-xs font-bold mb-2 flex items-center gap-1.5">
                <i class="fas fa-lock text-slate-400 text-[10px]"></i>
                Password <span class="text-rose-500">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  type="password"
                  name="password"
                  required
                  id="pass"
                  placeholder="••••••••"
                  class="w-full pl-4 pr-12 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
                <button
                  id="btn2"
                  class="absolute right-2 px-2 py-1 text-[10px] font-bold text-indigo-650 hover:bg-indigo-50 rounded"
                  type="button"
                  onclick="toggleInputType('pass','btn2')">
                  Show
                </button>
              </div>
            </div>
            <div>
              <label class="block text-slate-700 text-xs font-bold mb-2 flex items-center gap-1.5">
                <i class="fas fa-circle-check text-slate-400 text-[10px]"></i>
                Confirm Password <span class="text-rose-500">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  type="password"
                  name="conpassword"
                  required
                  id="conpass"
                  placeholder="••••••••"
                  class="w-full pl-4 pr-12 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition text-slate-800 placeholder-slate-400 font-medium text-sm">
                <button
                  id="btn1"
                  class="absolute right-2 px-2 py-1 text-[10px] font-bold text-indigo-650 hover:bg-indigo-50 rounded"
                  type="button"
                  onclick="toggleInputType('conpass','btn1')">
                  Show
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="border-t border-slate-100 pt-5">
          <label class="flex items-start cursor-pointer select-none">
            <input
              type="checkbox"
              name="terms"
              required
              class="mt-1 w-4.5 h-4.5 text-indigo-600 border-slate-350 rounded focus:ring-indigo-500/30">
            <span class="ml-2.5 text-slate-500 text-xs font-medium leading-relaxed">
              I confirm that the information provided is accurate and I agree to use this platform honestly. <span class="text-rose-500">*</span>
            </span>
          </label>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <button
            type="submit"
            class="flex-1 bg-gradient-to-r from-indigo-550 to-purple-600 bg-indigo-600 text-white px-6 py-3.5 rounded-xl hover:from-indigo-600 hover:to-purple-700 transition-all font-bold text-sm shadow hover:shadow-indigo-500/20 hover:scale-[1.02] flex items-center justify-center gap-2">
            <i class="fas fa-paper-plane text-xs"></i>
            Register
          </button>
          <button
            type="reset"
            class="bg-slate-50 hover:bg-slate-100 text-slate-600 px-5 py-3.5 rounded-xl border border-slate-200 transition-all font-bold text-sm">
            Clear
          </button>
        </div>

        <div class="text-center text-sm pt-2">
          <p class="text-slate-500 font-medium">Already have an account? <a href="/login" class="text-indigo-650 font-bold hover:underline">Log in</a></p>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function toggleInputType(inputId, btnid) {
    const input = document.getElementById(inputId);
    const btn = document.getElementById(btnid);
    if (input.type === "password") {
      input.type = "text";
      btn.textContent = "Hide";
    } else {
      input.type = "password";
      btn.textContent = "Show";
    }
  }
</script>

<%- include('partials/footer')%>
